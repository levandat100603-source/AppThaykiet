{
  "expo": {
    "name": "gym-scheduler-app",
    "slug": "gym-scheduler-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gymschedulerapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.lzd163.gymschedulerapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "notification": {
      "vapidPublicKey": "BMtiKAHmvlZDIIZIsKTI5cXzjHHQhlh5qOIQS7PBlFP1UDds6MOlslEccr6MZ5h7AJ10k2KNA17MykNICvkcT30"
    },
    "extra": {
      "API_URL": "http://127.0.0.1:8000/api",
      "router": {},
      "eas": {
        "projectId": "1c5f72c8-5c37-46bf-8d1c-0aab14a798a8"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
